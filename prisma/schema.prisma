generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id  String @id @default(uuid())
  title String
  price Float
  category String
  type String
  data DateTime @default(now()) 

  @@map("transactions")
}